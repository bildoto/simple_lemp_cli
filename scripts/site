#!/usr/bin/env bash
set -euo pipefail

AVAILABLE_DIR="/etc/nginx/sites-available"
ENABLED_DIR="/etc/nginx/sites-enabled"

require_dirs() {
    if [[ ! -d "$AVAILABLE_DIR" ]]; then
        echo "Error: $AVAILABLE_DIR does not exist."
        echo "Install nginx first, or create the Debian-style sites-available directory."
        exit 1
    fi

    if [[ ! -d "$ENABLED_DIR" ]]; then
        echo "Error: $ENABLED_DIR does not exist."
        echo "Install nginx first, or create the Debian-style sites-enabled directory."
        exit 1
    fi
}

create_site_prompt() {
    read -rp "Domain: " domain

    if [[ -z "$domain" ]]; then
        echo "No domain entered."
        return
    fi

    site-create "$domain"
}

list_sites() {
    require_dirs

    while true; do
        mapfile -t sites < <(
            find "$AVAILABLE_DIR" -maxdepth 1 -type f -name "*.conf" \
                -printf "%f\n" | sed 's/\.conf$//' | sort
        )

        if [[ ${#sites[@]} -eq 0 ]]; then
            echo
            echo "No sites found."
            echo
            echo "[1] Create new site"
            echo "[0] Exit"
            echo

            read -rp "Choose action: " action

            case "$action" in
                1)
                    create_site_prompt
                    echo
                    read -rp "Press Enter to continue..."
                    ;;
                0|q|quit|exit)
                    exit 0
                    ;;
                *)
                    echo "Invalid action."
                    echo
                    read -rp "Press Enter to continue..."
                    ;;
            esac

            continue
        fi

        echo
        echo "Sites"
        echo

        for i in "${!sites[@]}"; do
            domain="${sites[$i]}"

            if [[ -L "$ENABLED_DIR/$domain.conf" ]]; then
                status="active"
            else
                status="inactive"
            fi

            printf "[%d] %-35s %s\n" "$((i + 1))" "$domain" "$status"
        done

        echo
        echo "[c] Create new site"
        echo "[q] Quit"
        echo

        read -rp "Select site number: " choice

        case "$choice" in
            c|create)
                create_site_prompt
                echo
                read -rp "Press Enter to continue..."
                continue
                ;;
            q|quit|exit)
                exit 0
                ;;
        esac

        if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
            echo "Invalid selection."
            echo
            read -rp "Press Enter to continue..."
            continue
        fi

        index=$((choice - 1))

        if [[ -z "${sites[$index]:-}" ]]; then
            echo "Invalid selection."
            echo
            read -rp "Press Enter to continue..."
            continue
        fi

        selected="${sites[$index]}"
        site_menu "$selected"
    done
}

site_menu() {
    local domain="$1"

    while true; do
        echo
        echo "Selected: $domain"
        echo
        echo "[1]  Enable"
        echo "[2]  Disable"
        echo "[3]  Show credentials"
        echo "[4]  Create database"
        echo "[5]  Delete database"
        echo "[6]  Show DNS records"
        echo "[7]  Password protect path"
        echo "[8]  Remove password protection"
        echo "[9]  Add protection user"
        echo "[10] Remove protection user"
        echo "[11] Delete site"
        echo "[0]  Back"
        echo

        read -rp "Choose action: " action

        case "$action" in
            1)
                site-enable "$domain"
                ;;
            2)
                site-disable "$domain"
                ;;
            3)
                site-credentials "$domain"
                ;;
            4)
                site-database-create "$domain"
                ;;
            5)
                site-database-delete "$domain"
                ;;
            6)
                site-dns "$domain"
                ;;
            7)
                read -rp "Path to protect, for example /status/: " protect_path
                site-protect "$domain" "$protect_path"
                ;;
            8)
                site-unprotect "$domain"
                ;;
            9)
                read -rp "Protected path, for example /status/: " protect_path
                site-protect-user-add "$domain" "$protect_path"
                ;;
            10)
                read -rp "Protected path, for example /status/: " protect_path
                site-protect-user-remove "$domain" "$protect_path"
                ;;
            11)
                site-delete "$domain"
                return
                ;;
            0|b|back)
                return
                ;;
            *)
                echo "Invalid action."
                ;;
        esac

        echo
        read -rp "Press Enter to continue..."
    done
}

case "${1:-}" in
    create)
        site-create "${2:-}"
        ;;
    enable)
        site-enable "${2:-}"
        ;;
    disable)
        site-disable "${2:-}"
        ;;
    delete)
        site-delete "${2:-}"
        ;;
    credentials)
        site-credentials "${2:-}"
        ;;
    database-create|db-create)
        site-database-create "${2:-}" "${3:-}"
        ;;
    database-delete|db-delete)
        site-database-delete "${2:-}" "${3:-}"
		;;
	dns)
		site-dns "${2:-}"
        ;;
	protect)
		site-protect "${2:-}" "${3:-}"
		;;
	unprotect)
		site-unprotect "${2:-}" "${3:-}"
		;;
	protect-user-add)
        site-protect-user-add "${2:-}" "${3:-}" "${4:-}"
        ;;
    protect-user-remove)
        site-protect-user-delete "${2:-}" "${3:-}" "${4:-}"
        ;;
    ""|list)
        list_sites
        ;;
    *)
        echo "Usage:"
        echo "  site"
        echo "  site create example.com"
        echo "  site enable example.com"
        echo "  site disable example.com"
        echo "  site delete example.com"
        echo "  site credentials example.com"
        echo "  site database-create example.com logs"
        echo "  site database-delete example.com logs"
		echo "  site dns example.com"
		echo "  site unprotect example.com /status/"
		echo "  site protect-user-add example.com /status/ admin"
		echo "  site protect-user-remove example.com /status/ admin"        
		exit 1
        ;;
esac