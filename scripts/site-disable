#!/usr/bin/env bash
set -euo pipefail

DOMAIN="${1:-}"

if [[ -z "$DOMAIN" ]]; then
    echo "Usage: site-disable example.com"
    exit 1
fi

CONF="/etc/nginx/sites-available/$DOMAIN.conf"
LINK="/etc/nginx/sites-enabled/$DOMAIN.conf"

if [[ ! -f "$CONF" ]]; then
    echo "Error: site config not found: $CONF"
    exit 1
fi

if [[ ! -L "$LINK" ]]; then
    echo "Site is already disabled: $DOMAIN"
    exit 0
fi

rm "$LINK"

nginx -t
systemctl reload nginx

echo "Site disabled: $DOMAIN"