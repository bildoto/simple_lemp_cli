#!/usr/bin/env bash
set -euo pipefail

check_pass() {
    printf "✓ %s\n" "$1"
}

check_fail() {
    printf "✗ %s\n" "$1"
}

echo
echo "Server prerequisite check"
echo

# nginx

if command -v nginx >/dev/null 2>&1; then
    check_pass "nginx installed"
else
    check_fail "nginx not installed"
fi

if systemctl is-active --quiet nginx; then
    check_pass "nginx running"
else
    check_fail "nginx not running"
fi

# mariadb

if command -v mysql >/dev/null 2>&1; then
    check_pass "MariaDB client installed"
else
    check_fail "MariaDB client not installed"
fi

if systemctl is-active --quiet mariadb; then
    check_pass "MariaDB running"
else
    check_fail "MariaDB not running"
fi

# php-fpm

php_fpm_service="$(
    systemctl list-units \
        --type=service \
        --all \
        --no-legend 'php*-fpm.service' |
    awk '{print $1}' |
    head -n1
)"

if [[ -n "$php_fpm_service" ]]; then
    check_pass "PHP-FPM installed ($php_fpm_service)"

    if systemctl is-active --quiet "$php_fpm_service"; then
        check_pass "PHP-FPM running"
    else
        check_fail "PHP-FPM not running"
    fi
else
    check_fail "PHP-FPM not installed"
fi

# certbot

if command -v certbot >/dev/null 2>&1; then
    check_pass "certbot installed"
else
    check_fail "certbot not installed"
fi

# directories

if [[ -d /etc/nginx/sites-available ]]; then
    check_pass "/etc/nginx/sites-available exists"
else
    check_fail "/etc/nginx/sites-available missing"
fi

if [[ -d /etc/nginx/sites-enabled ]]; then
    check_pass "/etc/nginx/sites-enabled exists"
else
    check_fail "/etc/nginx/sites-enabled missing"
fi

if [[ -d /srv/www ]]; then
    check_pass "/srv/www exists"
else
    check_fail "/srv/www missing"
fi

if [[ -d /root/site-credentials ]]; then
    check_pass "/root/site-credentials exists"
else
    check_fail "/root/site-credentials missing"
fi

# nginx config

if nginx -t >/dev/null 2>&1; then
    check_pass "nginx configuration valid"
else
    check_fail "nginx configuration invalid"
fi

echo
