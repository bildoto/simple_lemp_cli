#!/usr/bin/env bash
set -euo pipefail

DOMAIN="${1:-}"

if [[ -z "$DOMAIN" ]]; then
    echo "Usage: site-credentials example.com"
    exit 1
fi

BASE_DB="${DOMAIN//./_}"
PRIMARY_USER="$BASE_DB"
CRED_FILE="/root/site-credentials/$DOMAIN.txt"

primary_pass=""
primary_host="localhost"

if [[ -f "$CRED_FILE" ]]; then
    primary_pass="$(
        awk '
            /^DB pass:/ {
                sub(/^DB pass:[[:space:]]*/, "")
                print
                exit
            }
        ' "$CRED_FILE"
    )"

    primary_host="$(
        awk '
            /^DB host:/ {
                sub(/^DB host:[[:space:]]*/, "")
                print
                exit
            }
        ' "$CRED_FILE"
    )"

    [[ -z "$primary_host" ]] && primary_host="localhost"
fi

echo
echo "Credentials for: $DOMAIN"
echo

if [[ -f "$CRED_FILE" ]]; then
    echo "Credentials file:"
    echo "  $CRED_FILE"
else
    echo "Credentials file not found:"
    echo "  $CRED_FILE"
fi

echo
echo "Databases:"
echo

mapfile -t DATABASES < <(
    mysql -NBe "SHOW DATABASES;" |
    awk -v base="$BASE_DB" '
        $0 == base || index($0, base "_") == 1 {
            print
        }
    ' | sort
)

if [[ ${#DATABASES[@]} -eq 0 ]]; then
    echo "  No databases found."
    echo
    exit 0
fi

for db in "${DATABASES[@]}"; do
    if [[ "$db" == "$BASE_DB" ]]; then
        echo "  $db"
        echo "    user:     $PRIMARY_USER"
        echo "    password: ${primary_pass:-unknown}"
        echo "    host:     $primary_host"
        echo
        continue
    fi

    if [[ -f "$CRED_FILE" ]] && grep -q "^### DATABASE-BEGIN: $db$" "$CRED_FILE"; then
        db_user="$db"

        db_pass="$(
            awk -v db="$db" '
                $0 == "### DATABASE-BEGIN: " db { in_block=1; next }
                $0 == "### DATABASE-END: " db { in_block=0 }
                in_block && /^DB pass:/ {
                    sub(/^DB pass:[[:space:]]*/, "")
                    print
                    exit
                }
            ' "$CRED_FILE"
        )"

        db_host="$(
            awk -v db="$db" '
                $0 == "### DATABASE-BEGIN: " db { in_block=1; next }
                $0 == "### DATABASE-END: " db { in_block=0 }
                in_block && /^DB host:/ {
                    sub(/^DB host:[[:space:]]*/, "")
                    print
                    exit
                }
            ' "$CRED_FILE"
        )"

        [[ -z "$db_host" ]] && db_host="localhost"

        echo "  $db"
        echo "    user:     $db_user"
        echo "    password: ${db_pass:-unknown}"
        echo "    host:     $db_host"
        echo
    else
        echo "  $db"
        echo "    user:     $PRIMARY_USER"
        echo "    password: uses primary database credentials"
        echo "    host:     $primary_host"
        echo
    fi
done